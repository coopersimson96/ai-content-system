# --------------------------------------------------------------------------
# Instagram Analytics Pipeline - environment variables
# --------------------------------------------------------------------------
# Copy this file to .env.local at the root of your Next.js app and fill in
# your own values. NEVER commit .env.local.
#
# All variables marked REQUIRED are needed for the pipeline to work.
# OPTIONAL variables enable extra features.
# --------------------------------------------------------------------------

# === Meta / Instagram Graph API (REQUIRED) ===
# Get these from https://developers.facebook.com/apps/
# See SKILL.md "Phase 1: Meta app + long-lived token" for the full walkthrough.
FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID
FACEBOOK_APP_SECRET=YOUR_FACEBOOK_APP_SECRET

# Long-lived (60-day) page access token. Refresh before it expires.
# Exchange short-lived → long-lived via:
#   curl "https://graph.facebook.com/v25.0/oauth/access_token?grant_type=fb_exchange_token&client_id=$FACEBOOK_APP_ID&client_secret=$FACEBOOK_APP_SECRET&fb_exchange_token=SHORT_LIVED_TOKEN"
FACEBOOK_ACCESS_TOKEN=YOUR_FACEBOOK_LONG_LIVED_TOKEN

# Numeric Facebook Page ID linked to your Instagram Business Account.
# Find via: GET https://graph.facebook.com/v25.0/me/accounts?access_token=...
FACEBOOK_PAGE_ID=YOUR_FACEBOOK_PAGE_ID

# Instagram Business Account ID (numeric). Optional - the pipeline derives
# this from the Page ID at runtime, but storing it lets scripts skip a hop.
INSTAGRAM_USER_ID=YOUR_INSTAGRAM_USER_ID

# === Supabase (REQUIRED) ===
# Create a new project at https://supabase.com/dashboard and run the
# migration in supabase/migrations/init.sql before anything else.
SUPABASE_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional: anon/publishable key, only needed if you build a public dashboard
# off this data and want client-side read access (which currently RLS denies).
# SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# === Notion (REQUIRED for Notion mirror; OPTIONAL otherwise) ===
# Create an internal integration at https://www.notion.so/my-integrations,
# then share both databases with the integration. See SKILL.md "Phase 3".
NOTION_TOKEN=YOUR_NOTION_INTEGRATION_TOKEN

# Datasource ID (NOT database ID) of your Content Analytics database.
# Get via: GET https://api.notion.com/v1/databases/{db_id}/data_sources
NOTION_ANALYTICS_DATASOURCE=YOUR_NOTION_ANALYTICS_DATASOURCE

# Optional: if you also keep a Script Library DB and want analytics rows
# to auto-link to scripts via Instagram Post URL.
NOTION_SCRIPT_DATASOURCE=YOUR_NOTION_SCRIPT_DATASOURCE

# Optional: bare database IDs, only needed for direct Notion API calls
# outside the datasource model.
# NOTION_ANALYTICS_DB=YOUR_NOTION_ANALYTICS_DB
# NOTION_SCRIPT_DB=YOUR_NOTION_SCRIPT_DB

# === Anthropic (REQUIRED for daily assess-performance routine) ===
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# === Creative Director routine variables (REQUIRED for assess-performance) ===
# These get substituted into prompts/creative-director-routine.md.
# Spend 5 minutes here - specific values produce much better notes.
CREATOR_NAME="Your Name"
CREATOR_NICHE="one sentence describing what you teach / make / talk about"
CREATOR_AUDIENCE="one sentence describing who watches and what they care about"

# === Vercel cron (REQUIRED on Vercel deploy) ===
# Vercel sets this header automatically when calling cron endpoints.
# Generate via: openssl rand -base64 32
CRON_SECRET=YOUR_RANDOM_CRON_SECRET
