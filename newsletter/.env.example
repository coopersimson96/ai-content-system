# Beehiiv API credentials (primary supported platform)
# Get these from: Beehiiv -> Settings -> Integrations -> API
BEEHIIV_API_KEY=your_api_key_here
BEEHIIV_PUBLICATION_ID=pub_your_publication_id_here

# -----------------------------------------------------------------------------
# Using a different platform?
# -----------------------------------------------------------------------------
# Mailchimp:
# MAILCHIMP_API_KEY=your_key
# MAILCHIMP_SERVER_PREFIX=us1
# MAILCHIMP_AUDIENCE_ID=your_list_id
#
# ConvertKit / Kit:
# CONVERTKIT_API_KEY=your_key
# CONVERTKIT_API_SECRET=your_secret
#
# Brevo (Sendinblue):
# BREVO_API_KEY=your_key
#
# Replace the respective api.py wrapper with one for your platform -
# see the skill README for the required method signatures.
